# =============================================================================
# offirst-starter Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# For local dev with docker-compose: postgresql://offirst:offirst@localhost:5432/offirst
DATABASE_URI=postgresql://offirst:offirst@localhost:5432/offirst

# -----------------------------------------------------------------------------
# Payload CMS (Required)
# -----------------------------------------------------------------------------
# Secret for signing JWT tokens - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# -----------------------------------------------------------------------------
# Application URLs (Required)
# -----------------------------------------------------------------------------
# Public URL of your application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# S3 Storage (Optional - for media uploads)
# -----------------------------------------------------------------------------
# For local dev with MinIO:
# S3_BUCKET=offirst
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=offirst
# S3_SECRET_KEY=offirst123

# For production with AWS S3 or compatible:
# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-east-1
